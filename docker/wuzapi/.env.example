# Recommended WuzAPI settings.
WUZAPI_ADMIN_TOKEN=troque-este-token
WUZAPI_GLOBAL_ENCRYPTION_KEY=troque-esta-chave-com-32-caracteres
WUZAPI_GLOBAL_HMAC_KEY=
WUZAPI_GLOBAL_WEBHOOK=

# Runtime defaults.
WUZAPI_PORT=8080
TZ=America/Sao_Paulo
WEBHOOK_FORMAT=json
SESSION_DEVICE_NAME=WuzAPI

# Database settings used by the compose file.
DB_USER=wuzapi
DB_PASSWORD=wuzapi
DB_NAME=wuzapi
DB_PORT=5432

# RabbitMQ credentials used by the compose file.
RABBITMQ_USER=wuzapi
RABBITMQ_PASSWORD=wuzapi
RABBITMQ_QUEUE=whatsapp_events

# Optional Cloudflare Tunnel.
# Create the tunnel in Cloudflare Zero Trust and paste the tunnel token here.
CLOUDFLARE_TUNNEL_TOKEN=
